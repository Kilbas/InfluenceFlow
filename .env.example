DB_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql://influenceflow:replace-with-strong-password@localhost:5432/influenceflow
AUTH_SECRET=replace-with-openssl-rand-hex-32
AUTH_URL=http://localhost:3000

# Host ports for Docker Compose (change if defaults collide with other projects)
APP_PORT=3001
DEV_DB_PORT=5433
ADMIN_INIT_EMAIL=owner@example.com
WORKSPACE_NAME=My Company

# Phase 2 additions
REDIS_URL=redis://localhost:6379

ANTHROPIC_API_KEY=sk-ant-replace-with-key
BRAVE_SEARCH_API_KEY=replace-with-key

# AES-256-GCM key for encrypting SMTP passwords. Generate with: openssl rand -hex 32
# WARNING: Do NOT change this after initial setup — rotating the key makes all stored
# SMTP passwords permanently undecryptable.
ENCRYPTION_KEY=replace-with-openssl-rand-hex-32
